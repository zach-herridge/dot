# Subtle terminal background shift when SSH'd (mocha base → slightly cooler navy)
if [[ -n $SSH_CONNECTION ]]; then
    printf '\033]11;#1a1b2e\033\\'
fi

source ~/dot/zsh/exports.zsh
source ~/dot/zsh/path.zsh
source ~/dot/zsh/tools.zsh
source ~/dot/zsh/history.zsh
source ~/dot/zsh/completions.zsh
source ~/dot/zsh/modern-zsh.zsh
source ~/dot/zsh/aliases.zsh
source ~/dot/zsh/functions.zsh
source ~/dot/zh/shell/zh.zsh
source ~/dot/zsh/aws-accounts.zsh
source ~/dot/zsh/terminal-title.zsh

command -v starship &>/dev/null && eval "$(starship init zsh)"

alias arcc-dev="cd $HOME/workplace/ArccApp/src/ARCCCliCore && node dist/cli/index.js"

export PATH="$HOME/.aim/mcp-servers:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export MESHCLAW_PROJECT_DIR="$HOME/.meshclaw-app"
